{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "",
  "buildCommand": null,
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "ibkrstatement.site"
        }
      ],
      "destination": "https://www.ibkrstatement.site/:path*",
      "permanent": true
    }
  ]
}
